# Axonometra environment variables.
# Copy to .env (gitignored) and fill in as needed. All variables are optional.

# Comma-separated allowlist of origins permitted to embed Axonometra via
# postMessage. Consumed by src/embed/embedConfig.ts. When unset, no origins
# are accepted. Use '*' for any origin (development only; logged as a warning).
# VITE_EMBED_ALLOWED_ORIGINS=https://example.com,https://app.example.com
