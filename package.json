{
  "name": "axonometra-core",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mantine/core": "^4.1.1",
    "@mantine/dropzone": "^4.1.1",
    "@mantine/hooks": "^4.1.1",
    "@mantine/notifications": "^4.2.11",
    "file-saver": "^2.0.5",
    "pixi-viewport": "^4.34.4",
    "pixi.js": "^6.3.0",
    "react": "^18.0.0",
    "react-device-detect": "^2.2.2",
    "react-dom": "^18.0.0",
    "tabler-icons-react": "^1.43.0",
    "zustand": "^3.7.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src e2e",
    "lint:fix": "eslint src e2e --fix",
    "format": "prettier --write \"{src,e2e}/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"*.{ts,json,html,md}\"",
    "format:check": "prettier --check \"{src,e2e}/**/*.{ts,tsx,js,jsx,json,css,html,md}\" \"*.{ts,json,html,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/file-saver": "^2.0.5",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
